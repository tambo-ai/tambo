{
  "name": "tambo",
  "version": "0.56.0",
  "description": "Tambo CLI for scaffolding and managing AI applications",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tambo-ai/tambo.git",
    "directory": "cli"
  },
  "homepage": "https://tambo.co",
  "module": "./dist/cli.js",
  "main": "./dist/cli.js",
  "bin": {
    "tambo": "./dist/cli.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/cli.js",
      "types": "./dist/cli.d.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "LICENSE",
    "!**/*.test.*",
    "!**/__tests__/**"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc --project tsconfig.build.json && pnpm run copy-registry",
    "copy-registry": "tsx scripts/copy-registry.ts",
    "dev": "concurrently -c blue.bold,green.bold \"pnpm run dev:esm\"",
    "dev:esm": "tsc --watch",
    "check-types": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "format": "prettier --write .",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format:lint": "pnpm run format && pnpm run lint:fix",
    "clean": "rimraf dist esm coverage"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "@tambo-ai/react": "workspace:*",
    "@tambo-ai/typescript-sdk": "^0.95.0",
    "@trpc/client": "^11.15.1",
    "@trpc/server": "^11.15.1",
    "chalk": "^5.6.0",
    "cli-table3": "^0.6.5",
    "clipboardy": "^5.0.2",
    "clsx": "^2.1.1",
    "cross-spawn": "^7.0.6",
    "date-fns": "^4.1.0",
    "deepmerge": "^4.3.1",
    "diff": "^8.0.3",
    "dotenv": "^17.4.0",
    "env-paths": "^4.0.0",
    "fast-equals": "^6.0.0",
    "inquirer": "^13.3.0",
    "js-yaml": "^4.1.0",
    "meow": "^14.1.0",
    "open": "^11.0.0",
    "ora": "^9.0.0",
    "postcss": "^8.5.3",
    "posthog-node": "^5.28.11",
    "react-markdown": "^10.1.0",
    "rehype-harden": "^1.1.7",
    "sanitize-html": "^2.17.0",
    "semver": "^7.7.3",
    "streamdown": "^2.3.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.19",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@tambo-ai/eslint-config": "workspace:*",
    "@tambo-ai/typescript-config": "workspace:*",
    "@tambo-ai/ui-registry": "workspace:*",
    "@types/cross-spawn": "^6.0.6",
    "@types/diffable-html": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.15",
    "@types/node-fetch": "^2.6.13",
    "@types/semver": "^7.7.1",
    "diffable-html": "^6.0.1",
    "jest": "^30.3.0",
    "memfs": "~4.51.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "eslint": "^9.39.4",
    "@eslint/js": "^9.39.4",
    "typescript-eslint": "^8.58.1"
  }
}
