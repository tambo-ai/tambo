{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": ["NODE_ENV", "TAMBO_SERVER_URL", "GITHUB_TOKEN"],
  "tasks": {
    "//#sync:showcase": {
      "cache": false,
      "inputs": [
        "cli/src/registry/**/*.tsx",
        "cli/src/registry/**/*.ts",
        "cli/src/registry/**/*.css",
        "cli/src/registry/**/config.json"
      ],
      "outputs": ["showcase/src/components/tambo/**"]
    },
    "build": {
      "dependsOn": ["^build", "//#sync:showcase"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": { "dependsOn": ["^lint"] },
    "check-types": { "dependsOn": ["^check-types"] },
    "dev": {
      "dependsOn": ["^build", "//#sync:showcase"],
      "cache": false,
      "persistent": true
    },
    "clean": { "cache": false, "persistent": true },
    "start": { "dependsOn": ["^build"] },
    "test": { "dependsOn": ["^test"] }
  }
}
