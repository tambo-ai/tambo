{
  "name": "@tambo-ai/client",
  "version": "1.1.1",
  "description": "Framework-agnostic client for Tambo AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tambo-ai/tambo.git",
    "directory": "packages/client"
  },
  "homepage": "https://tambo.co",
  "main": "./dist/index.js",
  "module": "./esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@tambo-ai/source": "./src/index.ts",
      "import": {
        "types": "./esm/index.d.ts",
        "default": "./esm/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "esm",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json && tsc-esm-fix --target=esm",
    "check-types": "tsc --noEmit",
    "dev": "concurrently \"npm run dev:cjs\" \"npm run dev:esm\"",
    "dev:cjs": "tsc -p tsconfig.cjs.json --watch",
    "dev:esm": "tsc -p tsconfig.esm.json --watch",
    "test": "jest --config jest.config.ts",
    "format": "prettier --write .",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "clean": "rimraf dist esm coverage"
  },
  "peerDependencies": {
    "zod": "^3.25.76 || ^4",
    "zod-to-json-schema": "^3.25.1"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "zod-to-json-schema": {
      "optional": true
    }
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.44",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-schema/spec": "^1.1.0",
    "@tambo-ai/typescript-sdk": "0.96.0",
    "fast-json-patch": "3.1.1",
    "partial-json": "0.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tambo-ai/eslint-config": "*",
    "@tambo-ai/typescript-config": "*",
    "@types/jest": "^30.0.0",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.19.15",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jsdoc": "^62.8.1",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.2.0",
    "prettier": "^3.8.3",
    "prettier-2": "npm:prettier@^2",
    "ts-jest": "^29.4.9",
    "tsc-esm-fix": "^3.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "zod": "^3.25.76 || ^4",
    "zod-to-json-schema": "^3.25.1"
  }
}
