{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "module": "CommonJS",
    "customConditions": null,
    "outDir": "./dist",
    "declaration": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "./dist", "./esm", "src/**/*.test.ts"]
}
